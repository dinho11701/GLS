{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["*"],
      "@lib/*": ["lib/*"]          // 👉 pointe sur le nouveau dossier
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
